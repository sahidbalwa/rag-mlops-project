# ==========================================
# RAG MLOPS PIPELINE ENVIRONMENT VARIABLES
# ==========================================

# 1. LLM Provider (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
LLM_PROVIDER=openai  # openai or huggingface

# 2. Vector Database (ChromaDB / Pinecone)
VECTOR_STORE_BACKEND=chroma  # chroma or pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=rag-index
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# 3. Embedding Model
EMBEDDING_PROVIDER=huggingface  # huggingface or openai

# 4. Retrieval & Reranking
COHERE_API_KEY=your_cohere_api_key_here

# 5. MLOps Extensibility (MLflow & LangSmith)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rag-experiments
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=rag-mlops-pipeline

# 6. Airflow Orchestration
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# 7. Monitoring (Prometheus & Grafana)
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# 8. Databases & Cache
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=mlops_db
REDIS_HOST=localhost
REDIS_PORT=6379

# 9. Cloud Providers (AWS / GCP - for artifacts/storage if needed)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=us-east-1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp/key.json
